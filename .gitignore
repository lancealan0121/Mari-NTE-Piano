# ============================================================================
# Python
# ============================================================================
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# venv / 套件管理
venv/
.venv/
env/
.env

# ============================================================================
# PyInstaller / Inno Setup 打包輸出
# ============================================================================
build/
dist/
*.manifest
# 保留 nte_piano.spec(這是 PyInstaller 設定檔，要進版本控制)
# 但忽略其他自動生成的 spec
*.spec.bak

# ============================================================================
# 專案執行階段產生物
# ============================================================================
# 開發測試用的 bench / cache(含 .tmp/test_cache 內的 cached musicxml)
.tmp/
# run.bat 跟 build.bat 的執行日誌
logs/
# 編輯器自動存檔(寫到 .tmp/autosave.txt，已被 .tmp/ 涵蓋，這裡再列一次保險)
autosave.txt
# atomic write 過程的臨時檔
*.tmp
# settings.json 載入失敗時的備份
settings.json.bad-*

# 音訊樣本 cache(nte_automation 執行時依 sr / degree / cut_off 自動生成)
*.npy

# ============================================================================
# 使用者譜面庫 — 大多為商業作品改編，不公開散布
# ============================================================================
songs/

# ============================================================================
# 開發者本地腳本(不公開)
# ============================================================================
# 一鍵上傳/更新到 GitHub,內含主人個人 repo URL 與 commit 流程,
# 不應出現在公開 repo
upload.bat

# ============================================================================
# IDE / 編輯器本地設定
# ============================================================================
# Claude Code 本地設定與 agent
.claude/settings.local.json
.claude/agents/

# VS Code / PyCharm / 其他
.vscode/
.idea/
*.swp
*.swo
*~

# ============================================================================
# 作業系統雜檔
# ============================================================================
.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/
